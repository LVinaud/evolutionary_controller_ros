# Source this file (or paste into ~/.bashrc) before launching either
# redis_coordinator or redis_worker. Both read $REDIS_URL by default.
#
# Get the URL from your hosted Redis provider's console. Examples:
#   - Upstash    → "Connect" tab → "redis-cli" or "Python" snippet,
#                  copy the rediss:// URL (TLS).
#   - Redis Cloud → Database details → public endpoint, then prefix
#                   "redis://default:<password>@<host>:<port>".
#
# DO NOT commit a filled-in version of this file. Rename to redis.env
# (which is gitignored) and source from there.

export REDIS_URL="rediss://default:REPLACE_TOKEN_HERE@REPLACE_HOST_HERE:6379"
