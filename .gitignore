__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# colcon artifacts (in case it's run from the package dir by mistake)
build/
install/
log/

# IDE
.vscode/
.idea/
*.swp

# Training logs and intermediate genomes — commit only the default seed
# and the all-time champion so fresh clones can run mission.launch.py
# without having to train first.
logs/
genomes/*
!genomes/.gitkeep
!genomes/best.npy
!genomes/best.json
